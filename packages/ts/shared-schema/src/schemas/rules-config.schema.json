{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rules-config.schema.json",
  "title": "RulesConfig",
  "description": "Game rules configuration — power calculation, XP, and turn settings",
  "type": "object",
  "required": ["id", "formatVersion", "name", "powerCalculation", "xpConfig", "turnConfig"],
  "properties": {
    "id": { "type": "string" },
    "formatVersion": { "type": "string" },
    "name": { "type": "string" },
    "powerCalculation": {
      "type": "object",
      "required": ["stepOrder"],
      "properties": {
        "stepOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["BASE_POWER", "AOE_BONUS", "SLOT_MODIFIER", "GENERAL_BONUS"]
          }
        },
        "stepMultipliers": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    },
    "xpConfig": {
      "type": "object",
      "required": ["baseXpPerBattle", "bonusXpForWin", "levelThresholds"],
      "properties": {
        "baseXpPerBattle": { "type": "number" },
        "bonusXpForWin": { "type": "number" },
        "levelThresholds": {
          "type": "array",
          "items": { "type": "number" }
        }
      }
    },
    "turnConfig": {
      "type": "object",
      "required": ["cardsDrawnPerTurn"],
      "properties": {
        "cardsDrawnPerTurn": { "type": "number" },
        "turnLimitIfApplicable": { "type": ["number", "null"] }
      }
    }
  }
}
